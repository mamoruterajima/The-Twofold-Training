<%= form_with(model: training_log, data: { controller: "exercise-select" }) do |form| %>
  <% if training_log.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(training_log.errors.count, "error") %> prohibited this training_log from being saved:</h2>
      <ul>
        <% training_log.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :workout_date, "トレーニング日", style: "display: block" %>
    <%= form.date_field :workout_date %>
  </div>

  <div style="margin-top: 15px;">
    <%= form.label :body_part, "部位" %>
    <%= form.select :body_part, ["胸", "肩", "腹", "腕", "背中", "足"], {}, 
        { data: { exercise_select_target: "category", action: "change->exercise-select#updateExercises" } } %>
  </div>

  <div style="margin-top: 15px;">
    <%= form.label :exercise_name, "種目名" %>
    <%# ここで「部位連動」と「前回記録取得」の両方のアクションを紐付け %>
    <%= form.select :exercise_name, [], {}, 
        { data: { 
            exercise_select_target: "exercise", 
            action: "change->exercise-select#fetchLastRecord" 
          } 
        } %>
    
    <div data-exercise-select-target="lastRecordDisplay" style="color: blue; margin-top: 5px; font-size: 0.9em; min-height: 1.2em;">
      <%# ここにJSで前回記録が出る %>
    </div>
  </div>

  <div style="margin-top: 15px;">
    <%= form.label :weight, "重量 (kg)", style: "display: block" %>
    <%= form.text_field :weight %>
  </div>

  <div>
    <%= form.label :sets, "セット数", style: "display: block" %>
    <%= form.number_field :sets %>
  </div>

  <div>
    <%= form.label :reps1, "1セット目レップ数", style: "display: block" %>
    <%= form.number_field :reps1 %>
  </div>

  <div>
    <%= form.label :reps2, "2セット目レップ数", style: "display: block" %>
    <%= form.number_field :reps2 %>
  </div>

  <div>
    <%= form.label :reps3, "3セット目レップ数", style: "display: block" %>
    <%= form.number_field :reps3 %>
  </div>

  <div>
    <%= form.label :interval, "インターバル (秒)", style: "display: block" %>
    <%= form.number_field :interval %>
  </div>

  <div>
    <%= form.label :memo, "メモ", style: "display: block" %>
    <%= form.text_area :memo %>
  </div>

  <div style="margin-top: 20px;">
    <%= form.submit "記録を保存する" %>
  </div>
<% end %>