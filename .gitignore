# Terraform
.terraform/
*.tfstate*
.terraform.lock.hcl
*.exe
*.pem

# Rails
/myapp/config/master.key
/myapp/tmp/pids/

# --- Terraform ---
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
.terraform.lock.hcl

# --- Rails (myapp配下) ---
myapp/config/master.key
myapp/tmp/pids/*
!myapp/tmp/pids/.keep
myapp/log/*.log
myapp/tmp/cache/
myapp/public/assets
myapp/vendor/bundle
myapp/config/database.yml

# DBの実データ（うっかり入らないように）
myapp/db/*.sqlite3
myapp/db/*.sqlite3-journal

# ユーザーがアップロードした画像（ストレージ容量を食うため）
myapp/storage/*
!myapp/storage/.keep
myapp/public/uploads

# Mac/Windows特有のゴミファイル（他人がクローンした時に邪魔にならないように）
.DS_Store
desktop.ini

# --- OS / IDE ---
.DS_Store
.vscode/
.idea/